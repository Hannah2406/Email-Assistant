# Account — Gmail: use an App Password (Google Account → Security → 2-Step → App passwords)
EMAIL_ADDRESS=
EMAIL_APP_PASSWORD=

# IMAP (receive) — Gmail defaults: host imap.gmail.com, port 993 (SSL)
IMAP_HOST=
IMAP_PORT=

# SMTP (send) — Gmail defaults: host smtp.gmail.com, port 587 (STARTTLS)
SMTP_HOST=
SMTP_PORT=

# Anthropic Claude API
ANTHROPIC_API_KEY=

# Optional: model id for classification and drafting
CLAUDE_MODEL=

# How often to check the inbox (seconds); e.g. 300 for five minutes
MAIL_POLL_INTERVAL_SECONDS=
